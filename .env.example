# Multi-country BA + browser runtime (aligned with openai-paypal knobs)
# Copy to .env and fill secrets. Do not commit real .env.

# -----------------------------------------------------------------------------
# Scenario profile
# -----------------------------------------------------------------------------
# test = pure protocol smoke (Phase0/1 probing)
# real = browser-capable defaults for live BA/OTP
PAYPAL_RUN_PROFILE=real

# Coarse runtime: protocol | headless | auto | roxy
# auto = Roxy if PAYPAL_ROXY_API_KEY present else headless
PAYPAL_RUNTIME_MODE=auto

# Fine risk modes (optional overrides; otherwise mapped from coarse mode)
PAYPAL_FINGERPRINT_SOURCE=auto
PAYPAL_DATADOME_MODE=auto
PAYPAL_MTR_RUNTIME=auto
PAYPAL_RISK_SIGNALS_MODE=auto

PAYPAL_DATADOME_HEADLESS_WAIT_SECONDS=14
PAYPAL_DATADOME_ROXY_WAIT_SECONDS=12
PAYPAL_MTR_HEADLESS_WAIT_SECONDS=20
PAYPAL_MTR_ROXY_WAIT_SECONDS=20
PAYPAL_RISK_HEADLESS_WAIT_SECONDS=12
PAYPAL_RISK_ROXY_WAIT_SECONDS=18

# After A-layer success, continue merchant B/C HTTP chain (default off)
PAYPAL_CONTINUE_MERCHANT=0

# -----------------------------------------------------------------------------
# Proxy
# -----------------------------------------------------------------------------
PAYPAL_PROXY_ENABLED=0
PAYPAL_USE_SYSTEM_PROXY=0
# PAYPAL_PROXY_URL=http://user:pass@host:port
# PAYPAL_PROXY_POOL=host:port:user:pass,http://user2:pass2@host2:port

# -----------------------------------------------------------------------------
# RoxyBrowser Local API (optional)
# -----------------------------------------------------------------------------
# PAYPAL_ROXY_API_KEY=
# PAYPAL_ROXY_API_HOST=127.0.0.1
# PAYPAL_ROXY_API_PORT=50000
# PAYPAL_ROXY_HEADLESS=1
# PAYPAL_ROXY_WORKSPACE_ID=
# PAYPAL_ROXY_PROJECT_ID=

# -----------------------------------------------------------------------------
# SMSBower auto OTP (default off; coexists with manual OTP)
# -----------------------------------------------------------------------------
SMSBOWER_ENABLED=0
# SMSBOWER_API_KEY=
# SMSBOWER_COUNTRY=73
# SMSBOWER_COUNTRY_MAP_JSON={"JP":"182","TH":"52","US":"12","BR":"73","GB":"16"}
# SMSBOWER_WAIT_SECONDS=30

# -----------------------------------------------------------------------------
# Diagnostics (keep off unless debugging)
# -----------------------------------------------------------------------------
PAYPAL_TRAFFIC_RECORD=0
PAYPAL_HEADLESS_DEBUG=0

# -----------------------------------------------------------------------------
# Web UI
# -----------------------------------------------------------------------------
PAYPAL_WEB_PRODUCTION=0
PAYPAL_WEB_ALLOW_DEBUG_LOGS=0
PAYPAL_WEB_MAX_ACTIVE_JOBS=4
PAYPAL_WEB_MAX_ACTIVE_JOBS_PER_DEVICE=2
PAYPAL_WEB_OTP_TIMEOUT_SECONDS=1800
PAYPAL_WEB_MAX_LOG_LINES=300
